#!/usr/bin/env bash
# Set a key=value in .ship/ship.local.md frontmatter.
# Creates the file if it doesn't exist. Updates in place if key exists.
# Usage: ship-config-set cli_prompt never
set -u

KEY="${1:-}"
VALUE="${2:-}"

if [ -z "$KEY" ] || [ -z "$VALUE" ]; then
  echo "Usage: ship-config-set <key> <value>" >&2
  exit 1
fi

REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null || echo "$PWD")
SETTINGS_FILE="$REPO_ROOT/.ship/ship.local.md"

mkdir -p "$(dirname "$SETTINGS_FILE")"

if [ ! -f "$SETTINGS_FILE" ]; then
  printf '%s\n' "---" "$KEY: $VALUE" "---" > "$SETTINGS_FILE"
  echo "Set $KEY: $VALUE"
  exit 0
fi

# Read existing frontmatter and body
FRONTMATTER=""
BODY=""
HAS_FM=false

if head -1 "$SETTINGS_FILE" | grep -q '^---$'; then
  HAS_FM=true
  # Extract frontmatter (between first and second ---)
  FRONTMATTER=$(awk 'BEGIN{i=0} /^---$/{i++;next} i==1{print}' "$SETTINGS_FILE")
  # Extract body (everything after second ---)
  BODY=$(awk 'BEGIN{i=0} /^---$/{i++;next} i>=2{print}' "$SETTINGS_FILE")
fi

if [ "$HAS_FM" = true ]; then
  if echo "$FRONTMATTER" | grep -q "^${KEY}:"; then
    # Update existing key
    FRONTMATTER=$(echo "$FRONTMATTER" | sed "s/^${KEY}:.*/${KEY}: ${VALUE}/")
  else
    # Append new key
    FRONTMATTER=$(printf '%s\n%s: %s' "$FRONTMATTER" "$KEY" "$VALUE")
  fi
  # Write back
  { printf '%s\n' "---"; printf '%s\n' "$FRONTMATTER"; printf '%s\n' "---"; printf '%s' "$BODY"; } > "$SETTINGS_FILE"
else
  # No frontmatter — prepend it, keep existing content as body
  EXISTING=$(cat "$SETTINGS_FILE")
  { printf '%s\n' "---" "$KEY: $VALUE" "---" ""; printf '%s' "$EXISTING"; } > "$SETTINGS_FILE"
fi

echo "Set $KEY: $VALUE"
