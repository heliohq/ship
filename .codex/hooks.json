{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.codex/ship/scripts/session-start.sh\"",
            "statusMessage": "Loading Ship learnings and design index"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.codex/ship/scripts/stop-gate.sh\"",
            "statusMessage": "Checking Ship auto state",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
